# PostgreSQL Configuration
POSTGRES_DB=creditdb
POSTGRES_USER=credituser
POSTGRES_PASSWORD=creditpass

# Service Ports
ORCHESTRATOR_PORT=8080
RISK_SERVICE_PORT=8081
RISK_SERVICE_GRPC_PORT=9000
FRONTEND_PORT=5173
POSTGRES_PORT=5432

# Local Development (when services run outside Docker)
# Set to localhost when running services locally
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://localhost:5432/creditdb
QUARKUS_GRPC_CLIENTS_RISK_SERVICE_HOST=localhost
QUARKUS_GRPC_CLIENTS_RISK_SERVICE_PORT=9000